{
  "info": {
    "name": "Shop Kit API",
    "_postman_id": "shop-kit-api-collection",
    "description": "Shop Kit REST API collection (self-contained).\n\n**Collection variables**\n- `baseUrl` — API root (default: production Railway URL; edit if needed)\n- `accessToken`, `refreshToken` — set by Login / Refresh tests\n- `accessTokenExpiresAt` — Unix ms mock expiry; pre-request refreshes via POST /auth/refresh-token when expired\n\nNo Postman Environment required. Import and run.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://shop-kit-api-production.up.railway.app" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "accessTokenExpiresAt", "value": "" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "(async () => {",
          "  const url = (pm.request.url && pm.request.url.toString()) || '';",
          "  if (url.indexOf('/auth/login') !== -1 || url.indexOf('/auth/refresh-token') !== -1) {",
          "    return;",
          "  }",
          "  const baseUrl = pm.collectionVariables.get('baseUrl') || 'http://localhost:3000';",
          "  const accessToken = pm.collectionVariables.get('accessToken');",
          "  const expiresAt = pm.collectionVariables.get('accessTokenExpiresAt');",
          "  const refreshToken = pm.collectionVariables.get('refreshToken');",
          "  if (!baseUrl || !refreshToken) {",
          "    return;",
          "  }",
          "  if (!expiresAt || !accessToken) {",
          "    return;",
          "  }",
          "  if (Date.now() < Number(expiresAt)) {",
          "    return;",
          "  }",
          "  pm.sendRequest({",
          "    url: baseUrl + '/auth/refresh-token',",
          "    method: 'POST',",
          "    header: { 'Content-Type': 'application/json' },",
          "    body: {",
          "      mode: 'raw',",
          "      raw: JSON.stringify({ refreshToken: refreshToken }),",
          "    },",
          "  }, function (err, res) {",
          "    if (!err && res.code === 200) {",
          "      const json = res.json();",
          "      pm.collectionVariables.set('accessToken', json.accessToken);",
          "      pm.collectionVariables.set('refreshToken', json.refreshToken);",
          "      pm.collectionVariables.set('accessTokenExpiresAt', Date.now() + 10 * 60 * 1000);",
          "    }",
          "  });",
          "})();"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Authentication: login, refresh, logout.",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"user123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Public endpoint. No Authorization header. Returns access and refresh tokens; use seeded user from prisma/seed (e.g. user@example.com / user123)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Response has valid tokens', function () {",
                  "  pm.expect(json.accessToken).to.be.a('string');",
                  "  pm.expect(json.refreshToken).to.be.a('string');",
                  "});",
                  "pm.collectionVariables.set('accessToken', json.accessToken);",
                  "pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "pm.collectionVariables.set('accessTokenExpiresAt', Date.now() + 10 * 60 * 1000);"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh-token",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh-token"]
            },
            "description": "Public endpoint. Body: refreshToken. Issues new token pair. Collection pre-request calls this automatically when accessTokenExpiresAt is in the past."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "  pm.collectionVariables.set('accessTokenExpiresAt', Date.now() + 10 * 60 * 1000);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "description": "Protected. Requires Bearer access token. Clears refresh token on server."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 401', function () {",
                  "  pm.expect([200, 401]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "description": "User registration and profile.",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\",\n  \"roles\": [\"USER\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            },
            "description": "Public endpoint. No Bearer token. Creates a user; email must be unique."
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Protected. Requires Bearer token (any authenticated role)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has email', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('email');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Products",
      "description": "Product catalog.",
      "item": [
        {
          "name": "Get Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            },
            "description": "Public endpoint. Lists products; no Authorization required."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response is array', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"iPhone 15\",\n  \"description\": \"Demo product\",\n  \"price\": 999.99,\n  \"discount\": 0,\n  \"category\": \"smartphone\",\n  \"features\": [\"5G\", \"OLED\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            },
            "description": "Protected. Requires Bearer token. Requires ADMIN or MANAGER role. Creates a product row."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 or 403', function () {",
                  "  pm.expect([201, 403]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  pm.test('Response has id', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('id');",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Categories",
